rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isNonEmptyString(value, maxLength) {
      return value is string && value.size() > 0 && value.size() <= maxLength;
    }

    function isLeaderboardDocumentOwner() {
      return isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.id == request.auth.uid + "_" + request.resource.data.date;
    }

    function hasValidLeaderboardFields() {
      return isNonEmptyString(request.resource.data.playerName, 24)
        && isNonEmptyString(request.resource.data.phoneNumber, 24)
        && request.resource.data.completionTimeSeconds is number
        && request.resource.data.attempts is number
        && request.resource.data.score is number
        && isNonEmptyString(request.resource.data.date, 10)
        && isNonEmptyString(request.resource.data.weekEndingDate, 10)
        && request.resource.data.keys().hasOnly([
          'userId',
          'playerName',
          'phoneNumber',
          'completionTimeSeconds',
          'attempts',
          'score',
          'date',
          'weekEndingDate',
          'createdAt',
          'updatedAt'
        ]);
    }

    match /leaderboard/{documentId} {
      allow read: if true;
      allow create: if isLeaderboardDocumentOwner() && hasValidLeaderboardFields();
      allow update: if isLeaderboardDocumentOwner()
        && hasValidLeaderboardFields()
        && request.resource.data.date == resource.data.date
        && request.resource.data.userId == resource.data.userId;
      allow delete: if false;
    }
  }
}
